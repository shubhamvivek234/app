PORT=3000
REACT_APP_BACKEND_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# ── Firebase Config ────────────────────────────────────────────────────────────
# Get values from: Firebase Console → Project Settings → Your apps → Web app
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# ── Cloudflare Turnstile ───────────────────────────────────────────────────────
# Site Key (public). Secret Key goes in backend/.env ONLY.
REACT_APP_TURNSTILE_SITE_KEY=
VITE_TURNSTILE_SITE_KEY=

# ── GIF Search (Tenor) ────────────────────────────────────────────────────────
# Get your own key: https://developers.google.com/tenor/guides/quickstart
# Do NOT use the demo key LIVDSRZULELA in production
REACT_APP_TENOR_API_KEY=
VITE_TENOR_API_KEY=

# ── Image Sources ─────────────────────────────────────────────────────────────
REACT_APP_UNSPLASH_ACCESS_KEY=
VITE_UNSPLASH_ACCESS_KEY=
REACT_APP_DROPBOX_APP_KEY=
VITE_DROPBOX_APP_KEY=
REACT_APP_GOOGLE_PICKER_API_KEY=
VITE_GOOGLE_PICKER_API_KEY=

# Google OAuth Client ID (public - same value as backend/.env)
REACT_APP_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
REACT_APP_SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Key ID is public (frontend). Secret goes in backend/.env ONLY.
REACT_APP_RAZORPAY_KEY_ID=
VITE_RAZORPAY_KEY_ID=
