# Core
MONGO_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379/0
DB_NAME=test_database
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=720
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=*

# AI
EMERGENT_LLM_KEY=sk-emergent-...

# Payments
STRIPE_API_KEY=sk_test_emergent     # Works in test mode
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# Firebase (storage)
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com

# Google OAuth + YouTube
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/oauth/google/callback
YOUTUBE_REDIRECT_URI=http://localhost:9500/oauth/callback
MOCK_GOOGLE_AUTH=false              # Set to "true" in dev to skip real OAuth

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:8001/api/oauth/reddit/callback

# Twitter / X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8001/api/oauth/twitter/callback

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8001/api/oauth/linkedin/callback

# TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8001/api/oauth/tiktok/callback

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8001/api/oauth/pinterest/callback

# Threads
THREADS_APP_ID=                     # Falls back to FACEBOOK_APP_ID if not set
THREADS_APP_SECRET=                 # Falls back to FACEBOOK_APP_SECRET if not set
THREADS_REDIRECT_URI=http://localhost:8001/api/oauth/threads/callback

# Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=http://localhost:8001/api/oauth/snapchat/callback

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8001/api/oauth/facebook/callback

# Instagram (shares Facebook app credentials)
INSTAGRAM_APP_ID=                   # Falls back to FACEBOOK_APP_ID if not set
INSTAGRAM_APP_SECRET=               # Falls back to FACEBOOK_APP_SECRET if not set
INSTAGRAM_REDIRECT_URI=             # Falls back to FACEBOOK_REDIRECT_URI if not set

# Discord / Bluesky
# No global OAuth credentials required.
# Discord uses a user-provided incoming webhook URL.
# Bluesky uses a user-provided handle + app password.

# Medium
# Medium no longer broadly allows new API integrations.
# If a user already has a legacy Medium integration token, they can paste it in the app.

# Observability (Stage 4)
SENTRY_DSN=                    # Sentry DSN (optional; error tracking disabled if empty)
ENV=development                # Environment name sent to Sentry (development/staging/production)

# Frontend
REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_SENTRY_DSN=          # Frontend Sentry DSN (optional)
